<% content_for :head do %>
<style>
 .demo{margin:1.5rem}
 #presence{margin:.4rem 0;min-height:1.5rem}.chip{color:#fff;padding:2px 8px;border-radius:999px;font-size:12px;margin-right:4px}
 #canvas{position:relative;height:60vh;border:1px solid #ddd;border-radius:10px;background:
   linear-gradient(#f3f4f6 1px,transparent 1px) 0 0/22px 22px,
   linear-gradient(90deg,#f3f4f6 1px,transparent 1px) 0 0/22px 22px,#fff;overflow:hidden;touch-action:none}
 .note{position:absolute;width:120px;height:78px;border-radius:7px;box-shadow:0 2px 6px rgba(0,0,0,.18);cursor:grab;padding:4px}
 .note textarea{width:100%;height:100%;border:0;background:transparent;resize:none;outline:none;font:13px/1.3 system-ui;color:#1f2937}
</style>
<% end %>
<div class="demo">
  <header>
    <h1>Collaborative whiteboard</h1>
    <%= render "nav" %>
    <p>
      Opaque state is a <code>Y.Map</code> of shape records (x, y, text, color).
      Double-click to add a note, drag to move, type to edit. Same shape
      tldraw/Excalidraw use — the same provider drops under their Yjs store.
    </p>
    <div id="presence"></div>
    <p id="status" class="status">connecting…</p>
  </header>
  <div id="canvas" data-document-id="<%= @document_id %>:whiteboard"></div>
</div>
<script src="/whiteboard.js" defer></script>
