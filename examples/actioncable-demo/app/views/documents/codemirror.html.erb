<% content_for :head do %>
<style>
 .demo{margin:1.5rem}
 #editor{border:1px solid #ddd;border-radius:8px;overflow:hidden}
 .cm-editor{height:60vh;font:13px/1.55 ui-monospace,SFMono-Regular,Menlo,monospace}
</style>
<% end %>
<div class="demo">
  <header>
    <h1>Collaborative code — CodeMirror 6</h1>
    <%= render "nav" %>
    <p>
      Opaque state is a <code>Y.Text</code>, bound with <code>y-codemirror.next</code>
      (live remote cursors). Open this page in another window to edit together.
    </p>
    <p id="status" class="status">connecting…</p>
  </header>
  <div id="editor" data-document-id="<%= @document_id %>:codemirror"></div>
</div>
<script src="/codemirror.js" defer></script>
